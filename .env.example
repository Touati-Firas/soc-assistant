# SOC Assistant - Example environment variables
# Copy this file to .env and fill in your own values before running the app.

# --- Elasticsearch SIEM ---
ELASTIC_URL=https://localhost:9200
ELASTIC_USER=elastic
ELASTIC_PASSWORD=your_elasticsearch_password
ELASTIC_VERIFY_CERTS=true
ELASTIC_CA_CERT=C:\path\to\ca.crt
ELASTIC_ALERT_INDEX=.alerts-security.alerts-*
ELASTIC_VECTOR_INDEX=soc-playbooks-vectors

# --- Groq LLM ---
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024
GROQ_TEMPERATURE=0.1

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMS=384

# --- Reports ---
REPORT_OUTPUT_DIR=./reports_output

# --- Notifications ---
NOTIFICATION_SEVERITY_THRESHOLD=high
SLACK_WEBHOOK_URL=

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
